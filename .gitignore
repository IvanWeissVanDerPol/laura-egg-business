# ============================================
# Granja Cabral - Git Ignore
# ============================================

# --- Archives (auto-generated, keep structure) ---
_archive/
!_archive/.gitkeep

# --- IDE & Editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS Files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg

# --- SpecStory (AI chat history - optional, remove if you want to track) ---
# Uncomment below to exclude SpecStory history
# .specstory/

# --- Temporary files ---
*.tmp
*.temp
*.bak
*.backup

# --- Generated reports (re-generated by CI) ---
.reports/
*.report.md
